struct __tensor_offsets;

template <class T, class E, class D, class... Tags, class Enable>
struct __tensor_offsets<tensor<T, E, D, Tags...>, Enable>
{
  using rank_type = typename E::rank_type;
  using index_type = typename E::index_type;

protected:
  using offsets_type = array<index_type, E::rank()>;

protected:
  constexpr index_type get_offset(rank_type) thread  const
  {
    return index_type();
  }
  constexpr index_type get_offset(rank_type) device  const
  {
    return index_type();
  }
#if defined(__HAVE_COHERENT__)
  constexpr index_type get_offset(rank_type) device coherent(device) const
  {
    return index_type();
  }
#endif
  constexpr index_type get_offset(rank_type) constant  const
  {
    return index_type();
  }
};

template <class T, class E, class D, class... Tags>
struct __tensor_offsets<tensor<T, E, D, Tags...>,
                        __tensor_detail::__has_tag_t<tensor_offset, Tags...>>
{
  using rank_type = typename E::rank_type;
  using index_type = typename E::index_type;

protected:
  using offsets_type = array<index_type, E::rank()>;

protected:

  __tensor_offsets() thread
    : _offsets([&]<size_t... Pos>(index_sequence<Pos...>) {
        return offsets_type{ (Pos ? index_type() : index_type())... };
      }(make_index_sequence<E::rank()>()))
  {
  }

  __tensor_offsets(const thread offsets_type &offsets) thread
    : _offsets(offsets)
  {
  }

  constexpr index_type get_offset(rank_type r) thread const
  {
    return _offsets[r];
  }

private:
  offsets_type _offsets;
};

