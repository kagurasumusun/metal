template <class T, class E, class D, class... Tags>
struct __tensor_observer<tensor<T, E, D, Tags...>, typename enable_if<(E::rank() == 0)>::type>
{
};

template <class T, class E, class D, class... Tags>
struct __tensor_observer<tensor<T, E, D, Tags...>, typename enable_if<(E::rank() > 0)>::type>
{
  using tensor_type = tensor<T, E, D, Tags...>;
  using extents_type = E;
  using index_type = typename extents_type::index_type;
  using size_type = typename extents_type::size_type;
  using rank_type = typename extents_type::rank_type;

  METAL_FUNC static constexpr size_t get_static_extent(rank_type r)
  {
    return extents_type::static_extent(r);
  }

  METAL_FUNC index_type get_extent(rank_type r) thread  const
  {
    if constexpr (extents_type::rank_dynamic() == 0)
    {
      return extents_type::static_extent(r);
    }
    else
    {
      if (extents_type::static_extent(r) != dynamic_extent)
        return extents_type::static_extent(r);

      const thread  tensor_type *self = static_cast<const thread  tensor_type *>(this);
      return __metal_get_extent_tensor(self->handle(),
                                       extents_type::rank(), r, size_type()) - self->get_offset(r);
    }
  }

  METAL_FUNC index_type get_stride(rank_type r) thread  const
  {
    return __metal_get_stride_tensor(static_cast<const thread  tensor_type *>(this)->handle(),
                                     extents_type::rank(), r, size_type());
  }
  METAL_FUNC index_type get_extent(rank_type r) device  const
  {
    if constexpr (extents_type::rank_dynamic() == 0)
    {
      return extents_type::static_extent(r);
    }
    else
    {
      if (extents_type::static_extent(r) != dynamic_extent)
        return extents_type::static_extent(r);

      const device  tensor_type *self = static_cast<const device  tensor_type *>(this);
      return __metal_get_extent_tensor(self->handle(),
                                       extents_type::rank(), r, size_type()) - self->get_offset(r);
    }
  }

  METAL_FUNC index_type get_stride(rank_type r) device  const
  {
    return __metal_get_stride_tensor(static_cast<const device  tensor_type *>(this)->handle(),
                                     extents_type::rank(), r, size_type());
  }
#if defined(__HAVE_COHERENT__)
  METAL_FUNC index_type get_extent(rank_type r) device coherent(device) const
  {
    if constexpr (extents_type::rank_dynamic() == 0)
    {
      return extents_type::static_extent(r);
    }
    else
    {
      if (extents_type::static_extent(r) != dynamic_extent)
        return extents_type::static_extent(r);

      const device coherent(device) tensor_type *self = static_cast<const device coherent(device) tensor_type *>(this);
      return __metal_get_extent_tensor(self->handle(),
                                       extents_type::rank(), r, size_type()) - self->get_offset(r);
    }
  }

  METAL_FUNC index_type get_stride(rank_type r) device coherent(device) const
  {
    return __metal_get_stride_tensor(static_cast<const device coherent(device) tensor_type *>(this)->handle(),
                                     extents_type::rank(), r, size_type());
  }
#endif
  METAL_FUNC index_type get_extent(rank_type r) constant  const
  {
    if constexpr (extents_type::rank_dynamic() == 0)
    {
      return extents_type::static_extent(r);
    }
    else
    {
      if (extents_type::static_extent(r) != dynamic_extent)
        return extents_type::static_extent(r);

      const constant  tensor_type *self = static_cast<const constant  tensor_type *>(this);
      return __metal_get_extent_tensor(self->handle(),
                                       extents_type::rank(), r, size_type()) - self->get_offset(r);
    }
  }

  METAL_FUNC index_type get_stride(rank_type r) constant  const
  {
    return __metal_get_stride_tensor(static_cast<const constant  tensor_type *>(this)->handle(),
                                     extents_type::rank(), r, size_type());
  }
};

template <class T, class Enable = void>
struct __tensor_accessor
{
};

template <class T, class E, class D, class... Tags>
struct __tensor_accessor<tensor<T, E, D, Tags...>, typename enable_if<(E::rank() == 0)>::type>
{
  using tensor_type = tensor<T, E, D, Tags...>;
  using element_type = T;
  using value_type = __tensor_detail::__tensor_value_t<element_type>;
  using index_type = typename E::index_type;
  using data_handle_type = __tensor_detail::__tensor_data_handle_t<element_type>;

  METAL_FUNC value_type get() thread  const
  {
    return __metal_load_tensor(static_cast<const thread  tensor_type *>(this)->handle(),
                               0, data_handle_type(), value_type());
  }

  template <class OtherIndexType>
  METAL_FUNC enable_if_t<(is_convertible_v<OtherIndexType, index_type>),
    value_type> get(thread const array<OtherIndexType, 0> &) thread  const
  {
    return get();
  }

  METAL_FUNC void set(value_type v) thread  const
  {
    __metal_store_tensor(static_cast<const thread  tensor_type *>(this)->handle(),
                         0, data_handle_type(), v);
  }

  template <class OtherIndexType>
  METAL_FUNC enable_if_t<(is_convertible_v<OtherIndexType, index_type>)>
  set(value_type v, thread const array<OtherIndexType, 0> &) thread  const
  {
    set(v);
  }

  METAL_FUNC value_type get() device  const
  {
    return __metal_load_tensor(static_cast<const device  tensor_type *>(this)->handle(),
                               0, data_handle_type(), value_type());
  }

  template <class OtherIndexType>
  METAL_FUNC enable_if_t<(is_convertible_v<OtherIndexType, index_type>),
    value_type> get(thread const array<OtherIndexType, 0> &) device  const
  {
    return get();
  }

  METAL_FUNC void set(value_type v) device  const
  {
    __metal_store_tensor(static_cast<const device  tensor_type *>(this)->handle(),
                         0, data_handle_type(), v);
  }

  template <class OtherIndexType>
  METAL_FUNC enable_if_t<(is_convertible_v<OtherIndexType, index_type>)>
  set(value_type v, thread const array<OtherIndexType, 0> &) device  const
  {
    set(v);
  }

#if defined(__HAVE_COHERENT__)
  METAL_FUNC value_type get() device coherent(device) const
  {
    return __metal_load_tensor(static_cast<const device coherent(device) tensor_type *>(this)->handle(),
                               0, data_handle_type(), value_type());
