  METAL_FUNC tensor(data_handle_type ptr,
                    thread const OtherExtentsType &_extents) thread
  {
    array<index_type, tensor::get_rank()> _strides;
    if constexpr (tensor::get_rank() > 0) {
      _strides[0] = 1;
      for (rank_type i = 1; i < tensor::get_rank(); ++i)
        _strides[i] = _strides[i - 1] * _extents.extent(i - 1);
    }

    [&]<size_t... Pos>(index_sequence<Pos...>)
    {
      __metal_init_strided_tensor(
          handle(), tensor::get_rank(), add_pointer_t<element_type>(ptr),
          array<index_type, tensor::get_rank()>{static_cast<index_type>(_extents.extent(Pos))...}.data(),
          array<index_type, tensor::get_rank()>{static_cast<index_type>(_strides[Pos])...}.data(),
          size_type());
    }(make_index_sequence<tensor::get_rank()>());
  }

