  // Slice
  template <size_t... OtherExtents, class... OtherIndexTypes>
  METAL_FUNC enable_if_t<
    ((tensor::get_rank() > 0) &&
     (is_convertible_v<OtherIndexTypes, index_type> && ...) &&
     (sizeof...(OtherExtents) == tensor::get_rank()) && (sizeof...(OtherIndexTypes) == tensor::get_rank())),
    __tensor_detail::__tensor_with_extents_t<extents<index_type, OtherExtents...>, tensor>>
  slice(OtherIndexTypes... index) thread const
  {
    return [&]<size_t... Pos>(index_sequence<Pos...>)
    {
      return __tensor_detail::__tensor_with_extents_t<extents<index_type, OtherExtents...>, tensor>(
          *this,
          offsets_type{static_cast<index_type>(index)...},
          offsets_type{(OtherExtents == dynamic_extent ? (this->get_extent(Pos) - static_cast<index_type>(index))
                                                       : static_cast<index_type>(OtherExtents))...}
      );
    }(make_index_sequence<tensor::get_rank()>());
  }

  template <class... OtherIndexTypes>
  METAL_FUNC enable_if_t<
    ((is_convertible_v<OtherIndexTypes, index_type> && ...) &&
