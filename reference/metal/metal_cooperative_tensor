class cooperative_tensor;

namespace __cooperative_tensor_detail
{
template <class CooperativeTensor>
class _iterator
{
public:
  using difference_type = typename CooperativeTensor::thread_index_type;
  using value_type = conditional_t<is_const_v<CooperativeTensor>,
                                   const typename CooperativeTensor::value_type,
                                   typename CooperativeTensor::value_type>;
  using pointer = add_pointer_t<value_type>;
  using reference = thread value_type &;

  using layout = typename remove_cv_t<CooperativeTensor>::layout;

public:
  // Copy constructor.
  METAL_FUNC _iterator(const thread _iterator &) thread = default;
  template <class _OtherCT>
  // Copy constructor from iterator to const_iterator.
  METAL_FUNC _iterator(const thread _iterator<_OtherCT> &other,
                       enable_if_t<is_convertible_v<typename _iterator<_OtherCT>::pointer, pointer>, thread void *> = nullptr) thread
    : _iterator(other._ct, other._idx)
  {
  }

public:
  METAL_FUNC friend
  bool operator==(const thread _iterator &_x,const thread _iterator &_y)
  {
    return _x._idx == _y._idx;
  }
  METAL_FUNC friend
  bool operator<(const thread _iterator &_x, const thread _iterator &_y)
  {
    return _x._idx < _y._idx;
  }
  METAL_FUNC friend
  bool operator>(const thread _iterator &_x, const thread _iterator &_y)
  {
    return _x._idx > _y._idx;
  }
  METAL_FUNC friend
  bool operator!=(const thread _iterator &_x, const thread _iterator &_y)
  {
    return !(_x == _y);
  }
  METAL_FUNC friend
  bool operator<=(const thread _iterator &_x, const thread _iterator &_y)
  {
    return !(_x > _y);
  }
  METAL_FUNC friend
  bool operator>=(const thread _iterator &_x, const thread _iterator &_y)
  {
    return !(_x < _y);
  }

  METAL_FUNC thread _iterator& operator+=(difference_type _n) thread
  {
    _idx += _n;
    return *this;
  }
  METAL_FUNC thread _iterator &operator++() thread
  {
    return *this += 1;
  }
  METAL_FUNC _iterator operator++(int) thread
  {
    _iterator _t(*this);
    ++(*this);
    return _t;
  }
  METAL_FUNC _iterator operator+(difference_type _n) thread const {
    _iterator _t(*this);
    _t += _n;
    return _t;
  }
  METAL_FUNC friend _iterator operator+(difference_type _n, const thread _iterator &_it)
  {
    return _it + _n;
  }

  METAL_FUNC thread _iterator& operator-=(difference_type _n) thread
  {
    _idx -= _n;
    return *this;
  }
  METAL_FUNC thread _iterator &operator--() thread
  {
    return *this -= 1;
  }
  METAL_FUNC _iterator operator--(int) thread
  {
    _iterator _t(*this);
    --(*this);
    return _t;
  }
  METAL_FUNC _iterator operator-(difference_type _n) thread const {
    _iterator _t(*this);
    _t -= _n;
    return _t;
  }
  METAL_FUNC friend difference_type operator-(const thread _iterator &_x, const thread _iterator &_y)
  {
    return _x._idx - _y._idx;
  }

  METAL_FUNC reference operator*() thread const
  {
    return _ct[_idx];
  };
  METAL_FUNC pointer operator->() thread const
  {
    return &(*this);
  };
  METAL_FUNC reference operator[](difference_type _n) thread const {
    return *(*this + _n);
  }

  METAL_FUNC array<typename CooperativeTensor::index_type, CooperativeTensor::get_rank()>
  get_multidimensional_index() thread const {
    return _ct.get_multidimensional_index(_idx);
  }

  METAL_FUNC bool is_valid_element() thread const {
    return _ct.is_valid_element(_idx);
  }

private:
  METAL_FUNC _iterator() thread = default;
  METAL_FUNC _iterator(thread CooperativeTensor &ct, difference_type idx) thread
      : _ct(ct), _idx(idx)
  {
  }

  thread CooperativeTensor &_ct;
  difference_type _idx;

  template <class> friend class _iterator;
  template <class, class, class> friend class metal::cooperative_tensor;
};

template <typename...>
struct make_void
{
  typedef void type;
};
template <typename... Ts>
using void_t = typename make_void<Ts...>::type;

template <class _Default, class _AlwaysVoid, template <class...> class _Op,
          class... _Args>
struct detector
{
  using value_t = false_type;
  using type = _Default;
};

template <class _Default, template <class...> class _Op, class... _Args>
struct detector<_Default, void_t<_Op<_Args...>>, _Op, _Args...>
{
  using value_t = true_type;
  using type = _Op<_Args...>;
};
struct nonesuch
{
  nonesuch() thread = delete;
  ~nonesuch() thread = delete;
  nonesuch(thread nonesuch const &) thread = delete;
  void operator=(thread nonesuch const &) thread = delete;
};
template <template <class...> class _Op, class... _Args>
using is_detected = typename detector<nonesuch, void, _Op, _Args...>::value_t;

#define HAS_INTERFACE(NAME)                                                     \
template <class _L>                                                             \
using has_interface_##NAME = decltype(_L::NAME, true);

#define HAS_INTERFACE_MDI(NAME)                                                 \
template <class _L, class _I, class _N>                                         \
using has_interface_##NAME =                                                    \
  decltype(_L::template NAME<_I, _N::value>, true);

template <class _L, class _From, class _To>
using has_interface_map_index =
  decltype(_L::template map_index<_From, _To>, true);

HAS_INTERFACE(construct)
HAS_INTERFACE(copy_construct)
HAS_INTERFACE(move_construct)
HAS_INTERFACE(copy_assign)
HAS_INTERFACE(move_assign)
HAS_INTERFACE(destroy)
HAS_INTERFACE(get_capacity)
HAS_INTERFACE(is_valid_element)
HAS_INTERFACE(get_element_pointer)
HAS_INTERFACE(get_element_index)
HAS_INTERFACE_MDI(get_multidimensional_index)

#undef HAS_INTERFACE
#undef HAS_INTERFACE_MDI

template <class T>
struct is_cooperative_tensor_impl : false_type
{
};
template <class T, class E, class L>
struct is_cooperative_tensor_impl<cooperative_tensor<T, E, L>> : true_type
{
};
} // __cooperative_tensor_detail

template <class T>
struct is_cooperative_tensor : __cooperative_tensor_detail::is_cooperative_tensor_impl<remove_cv_t<T>>
{
};
template <class T>
constexpr constant bool is_cooperative_tensor_v = is_cooperative_tensor<T>::value;

