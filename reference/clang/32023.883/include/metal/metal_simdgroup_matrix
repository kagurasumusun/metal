template <typename R, typename T, typename U, typename V, int K, int Rows, int Cols, bool ATranspose = false, bool BTranspose = false, bool Fast = false>
struct _simdgroup_multiply_accumulate_impl
{
};
template <typename R, typename T, typename U, typename V>
struct _simdgroup_multiply_accumulate_impl<R, T, U, V, 8, 8, 8>
{
  METAL_FUNC void operator()(thread simdgroup_matrix<R, 8, 8> &d, simdgroup_matrix<T, 8, 8> a, simdgroup_matrix<U, 8, 8> b, simdgroup_matrix<V, 8, 8> c) thread
  {
    d.thread_elements() = __metal_simdgroup_matrix_8x8_multiply_accumulate(a.thread_elements(), b.thread_elements(), c.thread_elements(), _simdgroup_matrix_storage_type_t<R, 8, 8>());
  }
};

template <typename T, int K, typename Enable = void>
struct _valid_simdgroup_multiply_operand_type : is_floating_point<T>
{
};
template <typename R, typename T, typename U, typename V, int K>
using _valid_simdgroup_multiply_accumulate_types = conjunction<is_floating_point<R>, _valid_simdgroup_multiply_operand_type<T, K>, _valid_simdgroup_multiply_operand_type<U, K>, is_floating_point<V>>;
template <typename R, typename T, typename U, typename V, int K>
constexpr constant bool _valid_simdgroup_multiply_accumulate_v = _valid_simdgroup_multiply_accumulate_types<R, T, U, V, K>::value;

template <typename R, typename T, typename U, typename V, int K, int Rows, int Cols>
METAL_FUNC enable_if_t<_valid_simdgroup_multiply_accumulate_v<R, T, U, V, K>>
simdgroup_multiply_accumulate(thread simdgroup_matrix<R, Cols, Rows> &d, simdgroup_matrix<T, K, Rows> a, simdgroup_matrix<U, Cols, K> b, simdgroup_matrix<V, Cols, Rows> c)
{
  _simdgroup_multiply_accumulate_impl<R, T, U, V, K, Rows, Cols>()(d, a, b, c);
}


template <typename R, typename T, typename U, int K>
using _valid_simdgroup_multiply_types = _valid_simdgroup_multiply_accumulate_types<R, T, U, R, K>;
template <typename R, typename T, typename U, int K>
constexpr constant bool _valid_simdgroup_multiply_v = _valid_simdgroup_multiply_types<R, T, U, K>::value;

template <typename R, typename T, typename U, int K, int Rows, int Cols>
METAL_FUNC enable_if_t<_valid_simdgroup_multiply_v<R, T, U, K>>
simdgroup_multiply(thread simdgroup_matrix<R, Cols, Rows> &d, simdgroup_matrix<T, K, Rows> a, simdgroup_matrix<U, Cols, K> b)
{
  simdgroup_multiply_accumulate(d, a, b, simdgroup_matrix<R, Cols, Rows>());
}

template <typename T, typename U, int K, int Rows, int Cols>
METAL_FUNC enable_if_t<_valid_simdgroup_multiply_v<T, T, U, K>, simdgroup_matrix<T, Cols, Rows>>
operator*(simdgroup_matrix<T, K, Rows> a, simdgroup_matrix<U, Cols, K> b)
{
  simdgroup_matrix<T, Cols, Rows> d;
  simdgroup_multiply(d, a, b);
  return d;
}

template <typename T, typename U, int Rows, int Cols>
METAL_FUNC enable_if_t<_valid_simdgroup_multiply_v<T, T, U, Cols>, thread simdgroup_matrix<T, Cols, Rows> &>
operator*=(thread simdgroup_matrix<T, Cols, Rows> &a, simdgroup_matrix<U, Rows, Cols> b)
{
  return a = a * b;
}


