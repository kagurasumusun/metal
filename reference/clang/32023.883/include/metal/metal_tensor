{
private:
  using __t_with_const = conditional_t<is_const_v<U>, const T, T>;
  using __t_with_cv = conditional_t<is_volatile_v<U>, volatile __t_with_const, __t_with_const>;
public:
  using type = __t_with_cv;
};
