template <typename T, typename Enable = void>
struct _is_simdgroup_matrix_element_impl : bool_constant<__is_metal_simdgroup_matrix_element(T)>
{
};
template <typename T>
struct is_simdgroup_matrix_element : _is_simdgroup_matrix_element_impl<remove_cv_t<T>>
{
};


METAL_FUNC constexpr bool _valid_simdgroup_matrix_size(int cols, int rows)
{
  return (cols == 8 && rows == 8)
      ;
}

template <typename T, int Cols, int Rows>
struct _simdgroup_matrix_storage_type
{
  typedef vec<T, Cols * Rows> type;
};
template <typename T, int Cols, int Rows>
using _simdgroup_matrix_storage_type_t = typename _simdgroup_matrix_storage_type<T, Cols, Rows>::type;
template <typename T, int K>
struct _simdgroup_init_diag_impl
{
};
template <typename T>
struct _simdgroup_init_diag_impl<T, 8>
{
  METAL_FUNC _simdgroup_matrix_storage_type_t<T, 8, 8> operator()(T value) const thread
  {
    return __metal_simdgroup_matrix_8x8_init_diag(value);
  }
};

template <typename T, int Cols, int Rows, typename Enable = void>
struct _simdgroup_matrix
{
};
template <typename T, int Cols, int Rows>
struct _simdgroup_matrix<T, Cols, Rows, enable_if_t<is_simdgroup_matrix_element<T>::value && _valid_simdgroup_matrix_size(Cols, Rows)>>
{
  using storage_type = _simdgroup_matrix_storage_type_t<T, Cols, Rows>;


  METAL_FUNC _simdgroup_matrix() thread = default;
  METAL_FUNC _simdgroup_matrix(const thread _simdgroup_matrix &that) thread = default;

  METAL_FUNC thread storage_type &thread_elements() thread
  {
    return t;
  }
  METAL_FUNC storage_type thread_elements() const thread
  {
    return t;
  }

  METAL_FUNC thread _simdgroup_matrix &operator=(const thread _simdgroup_matrix &that) thread = default;

protected:
  METAL_FUNC _simdgroup_matrix(storage_type t) thread : t(t)
  {
  }

private:
  storage_type t;
};
template <typename T, int Cols, int Rows = Cols>
struct simdgroup_matrix : _simdgroup_matrix<T, Cols, Rows>
{
  static_assert(is_simdgroup_matrix_element<T>::value, "invalid element type 'T' for 'simdgroup_matrix'");
  static_assert(_valid_simdgroup_matrix_size(Cols, Rows), "invalid size for 'simdgroup_matrix'");

  using _simdgroup_matrix<T, Cols, Rows>::_simdgroup_matrix;
};
template <typename T, int Cols>
struct simdgroup_matrix<T, Cols, Cols> : _simdgroup_matrix<T, Cols, Cols>
{
  static_assert(is_simdgroup_matrix_element<T>::value, "invalid element type 'T' for 'simdgroup_matrix'");
  static_assert(_valid_simdgroup_matrix_size(Cols, Cols), "invalid size for 'simdgroup_matrix'");

  using _simdgroup_matrix<T, Cols, Cols>::_simdgroup_matrix;

  METAL_FUNC explicit simdgroup_matrix(T value) thread : _simdgroup_matrix<T, Cols, Cols>(_simdgroup_init_diag_impl<T, Cols>()(value))
  {
  }
};

