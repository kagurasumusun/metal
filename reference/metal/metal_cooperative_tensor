template <class ElementType,
          class Extents,
          class Layout>
class [[sizeas(Layout::thread_storage_size())]] alignas(Layout::thread_storage_align()) cooperative_tensor
{
  static_assert(__mdspan_detail::is_extents_v<Extents>,
                "cooperative_tensor: Extents template parameter must be a specialization of extents.");
  static_assert(!is_array_v<ElementType>,
                "cooperative_tensor: ElementType template parameter may not be an array type");
  static_assert(!is_abstract_v<ElementType>,
                "cooperative_tensor: ElementType template parameter may not be an abstract class");
  static_assert(is_same_v<ElementType,
                          remove_cv_t<remove_addrspace_t<remove_coherent_t<ElementType>>>>,
                "cooperative_tensor: ElementType template parameter may not be qualified");
  static_assert(Layout::thread_storage_align() >= alignof(ElementType),
                "cooperative_tensor: alignment defined by Layout must accomodate ElementType");

  // Check for interfaces that must be implemented by 'Layout'
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_construct, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'construct' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_copy_construct, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'copy_construct' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_move_construct, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'move_construct' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_copy_assign, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'copy_assign' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_move_assign, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'move_assign' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_destroy, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'destroy' interface");

  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_is_valid_element, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'is_valid_element' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_get_multidimensional_index, Layout,
                    typename Extents::index_type, integral_constant<size_t, Extents::rank()>>::value,
                "cooperative_tensor: Layout needs to implement 'get_multidimensional_index' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_get_element_pointer, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'get_element_pointer' interface");
  static_assert(__cooperative_tensor_detail::is_detected<
                    __cooperative_tensor_detail::has_interface_get_element_index, Layout>::value,
                "cooperative_tensor: Layout needs to implement 'get_element_index' interface");

public:
  using element_type = ElementType;
  using value_type = element_type;
  using extents_type = Extents;
  using index_type = typename extents_type::index_type;
  using size_type = typename extents_type::size_type;
  using rank_type = typename extents_type::rank_type;
  using thread_index_type = int16_t;
  using thread_size_type = uint16_t;

  using data_handle_type = thread element_type *;
  using reference = thread element_type &;
  using const_reference = const thread element_type &;

  using layout = Layout;

public:
  using iterator = __cooperative_tensor_detail::_iterator<cooperative_tensor>;
  using const_iterator = __cooperative_tensor_detail::_iterator<const cooperative_tensor>;

public:
  METAL_FUNC static constexpr rank_type get_rank()
  {
    return extents_type::rank();
  }

public:
  METAL_FUNC cooperative_tensor() thread
  {
    Layout::construct(static_cast<thread void *>(this));
  }

  METAL_FUNC cooperative_tensor(const thread cooperative_tensor &other) thread
  {
    Layout::copy_construct(static_cast<thread void *>(this), static_cast<const thread void *>(&other));
  }

  METAL_FUNC cooperative_tensor(thread cooperative_tensor &&other) thread
  {
    Layout::move_construct(static_cast<thread void *>(this), static_cast<thread void *>(&other));
  }

  METAL_FUNC thread cooperative_tensor& operator=(const thread cooperative_tensor &other) thread
  {
    return Layout::copy_assign(static_cast<thread void *>(this), static_cast<const thread void *>(&other));
  }

  METAL_FUNC thread cooperative_tensor& operator=(thread cooperative_tensor &&other) thread
  {
    return Layout::move_assign(static_cast<thread void *>(this), static_cast<thread void *>(&other));
  }

  METAL_FUNC ~cooperative_tensor() thread
  {
    Layout::destroy(static_cast<thread void *>(this));
  }

public:
  METAL_FUNC thread_size_type get_capacity() thread const
  {
    return Layout::get_capacity(static_cast<const thread void *>(this));
  }

  METAL_FUNC bool is_valid_element(thread_index_type idx) thread const
  {
    return static_cast<bool>(Layout::is_valid_element(static_cast<const thread void *>(this),
                                                      static_cast<thread_index_type>(idx)));
  }
  METAL_FUNC bool is_valid_element(const_iterator it) thread const
  {
    return is_valid_element(it._idx);
  }
  METAL_FUNC bool is_valid_element(const thread element_type *ptr) thread const
  {
    return is_valid_element(get_iterator(ptr));
  }

  METAL_FUNC array<index_type, get_rank()>
  get_multidimensional_index(thread_index_type idx) thread const
  {
    return Layout::template get_multidimensional_index<index_type, get_rank()>(static_cast<const thread void *>(this), idx);
  }
  METAL_FUNC array<index_type, get_rank()>
  get_multidimensional_index(const_iterator it) thread const
  {
    return get_multidimensional_index(it._idx);
  }
  METAL_FUNC array<index_type, get_rank()>
  get_multidimensional_index(const thread element_type *ptr) thread const
  {
    return get_multidimensional_index(get_iterator(ptr));
  }

  METAL_FUNC reference operator[](thread_index_type idx) thread
  {
    return *static_cast<data_handle_type>(Layout::get_element_pointer(static_cast<thread void *>(this), idx));
  }
  METAL_FUNC const_reference operator[](thread_index_type idx) thread const
  {
    return *static_cast<data_handle_type>(Layout::get_element_pointer(static_cast<const thread void *>(this), idx));
  }

  METAL_FUNC value_type get(thread_index_type idx) thread const
  {
    return is_valid_element(idx) ? (*this)[idx] : value_type();
  }
  METAL_FUNC value_type get(const_iterator it) thread const
  {
    return get(it._idx);
  }
  METAL_FUNC value_type get(const thread element_type *ptr) thread const
  {
    return get(get_iterator(ptr));
  }

  METAL_FUNC void set(thread_index_type idx, value_type v) thread
  {
    if (is_valid_element(idx))
      (*this)[idx] = v;
  }
  METAL_FUNC void set(iterator it, value_type v) thread
  {
    set(it._idx, v);
  }
  METAL_FUNC void set(thread element_type *ptr, value_type v) thread
  {
    set(get_iterator(ptr), v);
  }

  template <class T, class E, class... Tags>
  METAL_FUNC enable_if_t<(is_same_v<element_type, typename tensor<T, E, tensor_handle, Tags...>::value_type> &&
                          get_rank() >= E::rank())>
  load(tensor<T, E, tensor_handle, Tags...> t) thread
  {
    Layout::load(static_cast<thread void *>(this), t);
  }

  template <class T, class E, class... Tags>
  METAL_FUNC enable_if_t<(is_same_v<element_type, typename tensor<T, E, tensor_inline, Tags...>::value_type> &&
                          get_rank() >= E::rank())>
  load(const thread tensor<T, E, tensor_inline, Tags...> &t) thread
  {
    Layout::load(static_cast<thread void *>(this), t);
  }


  template <class T, class E, class... Tags>
  METAL_FUNC enable_if_t<(is_same_v<element_type, typename tensor<T, E, tensor_handle, Tags...>::value_type> &&
                          get_rank() <= E::rank())>
  store(tensor<T, E, tensor_handle, Tags...> t) thread const
  {
    Layout::store(static_cast<const thread void *>(this), t);
  }

  template <class T, class E, class... Tags>
  METAL_FUNC enable_if_t<(is_same_v<element_type, typename tensor<T, E, tensor_inline, Tags...>::value_type> &&
                          get_rank() <= E::rank())>
  store(const thread tensor<T, E, tensor_inline, Tags...> &t) thread const
  {
    Layout::store(static_cast<const thread void *>(this), t);
  }


  METAL_FUNC iterator get_iterator(thread_index_type idx) thread
  {
    return iterator(*this, static_cast<thread_index_type>(idx));
  }
  METAL_FUNC iterator get_iterator(const thread element_type *ptr) thread
  {
    return get_iterator(Layout::get_element_index(static_cast<const thread void *>(this),
                                              static_cast<const thread void *>(ptr)));
  }

  METAL_FUNC const_iterator get_iterator(thread_index_type idx) thread const
  {
    return const_iterator(*this, static_cast<thread_index_type>(idx));
  }
  METAL_FUNC const_iterator get_iterator(const thread element_type *ptr) thread const
  {
    return get_iterator(Layout::get_element_index(static_cast<const thread void *>(this),
                                                  static_cast<const thread void *>(ptr)));
  }

  template <class OtherIterator>
  METAL_FUNC enable_if_t<__cooperative_tensor_detail::is_detected<
                             __cooperative_tensor_detail::has_interface_map_index,
                           layout, OtherIterator, iterator>::value,
                         iterator>
  map_iterator(OtherIterator it) thread
  {
    return iterator(*this, layout::template map_index<OtherIterator, iterator>(
        static_cast<const thread void *>(&it._ct), it._idx, static_cast<const thread void *>(this)));
  }
  template <class OtherIterator>
  METAL_FUNC enable_if_t<__cooperative_tensor_detail::is_detected<
                             __cooperative_tensor_detail::has_interface_map_index,
                           layout, OtherIterator, iterator>::value,
                         const_iterator>
  map_iterator(OtherIterator it) thread const
  {
    return const_iterator(*this, layout::template map_index<OtherIterator, iterator>(
        static_cast<const thread void *>(&it._ct), it._idx, static_cast<const thread void *>(this)));
  }

  iterator begin() thread
  {
    thread_index_type idx = 0;
    return get_iterator(idx);
  }
  const_iterator begin() thread const
  {
    thread_index_type idx = 0;
    return get_iterator(idx);
  }

  iterator end() thread
  {
    return get_iterator(get_capacity());
  }
  const_iterator end() thread const
  {
    return get_iterator(get_capacity());
  }
};
